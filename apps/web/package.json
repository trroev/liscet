{
  "name": "web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "portless": "liscet",
  "scripts": {
    "build": "NODE_ENV=production pnpm with-env next build",
    "dev": "portless run pnpm with-env next dev --turbopack",
    "start": "pnpm with-env next start",
    "typecheck": "next typegen && tsc --noEmit",
    "with-env": "dotenvx run --convention=nextjs --",
    "generate:types": "pnpm with-env payload generate:types",
    "generate:importmap": "pnpm with-env payload generate:importmap",
    "migrate": "pnpm with-env payload migrate",
    "migrate:create": "pnpm with-env payload migrate:create",
    "rules:reevaluate": "pnpm with-env payload run src/scripts/reevaluate.ts --",
    "seed": "pnpm with-env payload run src/scripts/seed.ts --",
    "test": "vitest run",
    "postinstall": "if [ -z \"$CI\" ] && [ -f .env.keys ]; then pnpm generate:types && pnpm generate:importmap; fi",
    "clean": "rm -rf .turbo .next dist storybook-static coverage *.tsbuildinfo test-results playwright-report"
  },
  "dependencies": {
    "@date-fns/tz": "catalog:",
    "@payloadcms/live-preview-react": "^3.85.0",
    "@payloadcms/next": "^3.85.0",
    "@payloadcms/plugin-seo": "catalog:",
    "@payloadcms/richtext-lexical": "catalog:",
    "@payloadcms/storage-vercel-blob": "catalog:",
    "@remixicon/react": "catalog:",
    "@repo/auth": "workspace:*",
    "@repo/chrome": "workspace:*",
    "@repo/db-seed": "workspace:*",
    "@repo/emails": "workspace:*",
    "@repo/env": "workspace:*",
    "@repo/logger": "workspace:*",
    "@repo/observability": "workspace:*",
    "@repo/payload": "workspace:*",
    "@repo/rules-engine": "workspace:*",
    "@repo/tailwind": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/ui": "workspace:*",
    "@repo/utils": "workspace:*",
    "@sentry/nextjs": "catalog:",
    "@tanstack/react-form": "^1.32.0",
    "@tanstack/react-query": "catalog:",
    "@vercel/blob": "catalog:",
    "better-auth": "catalog:",
    "date-fns": "catalog:",
    "minisearch": "^7.2.0",
    "next": "catalog:",
    "next-themes": "catalog:",
    "payload": "catalog:",
    "posthog-js": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-error-boundary": "^6.1.1",
    "react-schemaorg": "^2.0.1",
    "schema-dts": "catalog:",
    "server-only": "^0.0.1",
    "slugify": "catalog:",
    "ts-pattern": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/storybook-config": "workspace:*",
    "@repo/testing": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "jsdom": "catalog:",
    "portless": "catalog:",
    "storybook": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
