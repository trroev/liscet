{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "stream",
  "globalEnv": [
    "BASE_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "BLOB_READ_WRITE_TOKEN",
    "CI",
    "CLOUDINARY_API_KEY",
    "CLOUDINARY_API_SECRET",
    "CLOUDINARY_CLOUD_NAME",
    "DATABASE_URL",
    "EMAIL_FROM",
    "NEXT_PUBLIC_SENTRY_DSN",
    "NODE_ENV",
    "PAYLOAD_ADMIN_EMAIL",
    "PAYLOAD_ADMIN_PASSWORD",
    "PAYLOAD_ADMIN_PREFILL_ONLY",
    "PAYLOAD_SECRET",
    "RESEND_API_KEY",
    "REVALIDATION_SECRET",
    "SENTRY_AUTH_TOKEN",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "VERCEL_URL"
  ],
  "globalPassThroughEnv": [
    "PAYLOAD_MIGRATING",
    "PORTLESS",
    "SKIP_ENV_VALIDATION"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"]
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "typecheck": {
      "dependsOn": ["transit"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "generate:types": {
      "cache": false
    },
    "test": {},
    "coverage": {
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
